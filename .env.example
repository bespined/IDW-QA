# Canvas Credentials
# Get your token: Canvas → Profile → Settings → New Access Token
CANVAS_TOKEN=your_canvas_api_token
CANVAS_DOMAIN=canvas.asu.edu
CANVAS_COURSE_ID=123456

# Dev / Sandbox instance (optional)
# CANVAS_DEV_TOKEN=your_dev_token
# CANVAS_DEV_DOMAIN=canvas-dev.asu.edu
# CANVAS_DEV_COURSE_ID=789012

# Active instance: "prod" or "dev" (default: prod)
CANVAS_ACTIVE_INSTANCE=prod

# Safety: set to true to prevent any writes to Canvas
# CANVAS_READ_ONLY=false
