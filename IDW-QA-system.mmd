%%{init: {'theme': 'dark', 'themeVariables': {'fontSize': '14px'}}}%%

%% IDW QA Full System Diagram
%% Last updated: 2026-03-28

flowchart TD

    %% WORKFLOW A: NEW COURSE DEVELOPMENT

    subgraph WF_A["WORKFLOW A: New Course Development"]
        direction TB

        A1(["ID starts building course"]) --> A2

        subgraph A_SELF["ID Self-Audit Loop"]
            A2["ID runs self-audit via Claude Code<br/>audit_purpose = self_audit<br/>All 25 standards checked"] --> A3
            A3["Findings to Supabase<br/>reviewer_tier assigned per finding<br/>evidence captured: content_excerpt + canvas_link"] --> A4
            A4["ID reviews own findings<br/>in Vercel app"] --> A5{"Issues<br/>to fix?"}
            A5 -->|Yes| A6["ID remediates via Claude Code<br/>Stage, Preview, Push"]
            A6 --> A2
        end

        A5 -->|Satisfied| A7["ID clicks Submit for QA Review<br/>status = pending_qa_review"]
    end

    %% WORKFLOW B: QA REVIEW OF ID EXISTING FINDINGS

    subgraph WF_B["QA REVIEW: New Course Gate"]
        direction TB

        B0["Course appears in<br/>Pending Review queue<br/>on Vercel app"] --> B1
        B1["QA team assigns IDAs<br/>to review IDs existing findings"] --> B2

        subgraph B_IDA["IDA Review: Col B findings only"]
            B2["IDAs open session in Vercel app<br/>See ONLY id_assistant tier findings"] --> B3
            B3["Evidence shown inline:<br/>content excerpt + Canvas link<br/>IDA clicks Canvas link to verify"] --> B4
            B4["Verdict each Col B finding:<br/>Agree / Disagree / Not an Issue / N/A<br/>If Disagree: type corrected_finding"]
        end

        B4 --> B5

        subgraph B_ID["QA Team ID Review: All findings"]
            B5["QA team IDs open same session<br/>See ALL findings: Col B + Col C"] --> B6
            B6["Verdict Col C findings<br/>qualitative: Blooms alignment,<br/>UDL, assessment design, etc."] --> B7
            B7["Review IDA verdicts on Col B<br/>Override if needed with reason"]
        end

        B7 --> B8{"Revisions<br/>needed?"}
        B8 -->|Yes| B9["status = revisions_required<br/>audit_round increments<br/>ID sees feedback in Vercel app"]
        B9 --> A2
        B8 -->|No| B10["launch_gate_approved = true<br/>Course launches"]
    end

    A7 --> B0

    %% WORKFLOW C: RECURRING COURSE AUDIT

    subgraph WF_C["WORKFLOW C: Recurring Course Audit - QA Team Only"]
        direction TB

        C1(["QA team triggers audit<br/>via Claude Code using QA token"]) --> C2
        C2["Findings to Supabase<br/>audit_purpose = recurring<br/>reviewer_tier assigned per finding"] --> C3
        C3["QA team assigns IDAs<br/>to review session"] --> C4

        subgraph C_IDA["IDA Review: Col B findings only"]
            C4["IDAs review Col B findings<br/>in Vercel app<br/>Verify via Canvas link"] --> C5
            C5["Agree / Disagree / Not an Issue / N/A<br/>If Disagree: type corrected_finding"]
        end

        C5 --> C6

        subgraph C_ID["QA Team ID Review: All findings"]
            C6["QA team IDs verdict<br/>ALL findings Col B + Col C"] --> C7
            C7["Session complete<br/>All findings verdicted"]
        end

        C7 --> C8["Airtable sync fires automatically"]
        C8 --> C9["Remediation is PASSIVE:<br/>Findings visible in Airtable<br/>Faculty or IDs fix if they have time<br/>NOT launch-gated"]
    end

    %% DATA FLOW

    subgraph DATA["DATA FLOW"]
        direction LR

        D1["Every verdict click<br/>writes to Supabase immediately"] --> D2
        D2["Enables resume:<br/>IDA closes tab, comes back tomorrow<br/>picks up where they left off"] --> D3
        D3["Session complete trigger:<br/>all findings have a verdict<br/>including N/A"] --> D4
        D4["Batch sync to Airtable<br/>one API call per session"]
        D3 --> D5["Nightly catch-up job<br/>syncs incomplete sessions"]
    end

    %% RLHF LOOP

    subgraph RLHF["RLHF FEEDBACK LOOP"]
        direction TB

        R1["Disagreements + corrected_findings<br/>accumulate in finding_feedback<br/>IDA overrides tracked via original_decision"] --> R2
        R2["Admin reviews patterns<br/>on Vercel admin dashboard"] --> R3
        R3{"Diagnose<br/>root cause"}
        R3 -->|Prompt issue| R4a["AI misapplied enrichment context<br/>Fix: update audit skill prompts"]
        R3 -->|Enrichment gap| R4b["standards_enrichment.yaml is<br/>vague or incomplete<br/>Fix: add examples, criteria, research"]
        R3 -->|Standard ambiguous| R4c["standards.yaml criterion<br/>is unclear<br/>Fix: rewrite criterion text"]
        R3 -->|Check bug| R4d["deterministic_checks.py<br/>has a logic error<br/>Fix: update hardcoded check"]
        R4a --> R5["update-idw distributes<br/>changes via git pull"]
        R4b --> R5
        R4c --> R5
        R4d --> R5
        R5 --> R6["Next audit run<br/>uses improved prompts"]
    end

    %% SYSTEM COMPONENTS

    subgraph STACK["SYSTEM COMPONENTS"]
        direction TB

        subgraph CLAUDE["Claude Code - IDs + QA team"]
            CC1["audit skill<br/>Pass 1: deterministic_checks.py<br/>Pass 2: LLM + standards_enrichment.yaml"]
            CC2["course-review skill<br/>Fix queue from Supabase"]
            CC3["staging skill<br/>Stage, Preview, Push"]
            CC4["qa-concierge<br/>Guided entry point"]
        end

        subgraph VERCEL["Vercel App - All roles"]
            V1["IDA View<br/>Col B findings only<br/>Agree / Disagree / Not an Issue / N/A"]
            V2["ID View<br/>All findings + QA feedback<br/>Submit for QA Review button"]
            V3["QA Team View<br/>Pending Review queue<br/>Assign IDAs + override verdicts"]
            V4["Admin View<br/>Error queue + RLHF patterns<br/>IDA quality tracking<br/>Enrichment card effectiveness<br/>Tester + course assignment mgmt"]
        end

        subgraph SUPA["Supabase - Source of truth"]
            S1["audit_sessions<br/>audit_purpose, audit_round, status<br/>launch_gate_approved"]
            S2["audit_findings<br/>reviewer_tier, content_excerpt<br/>canvas_link, criterion_id"]
            S3["finding_feedback<br/>agree/disagree/not_an_issue/N/A<br/>corrected_finding, original_decision<br/>override tracking"]
            S4["testers<br/>name, role, UUID<br/>email + password auth"]
            S5["tester_course_assignments<br/>IDAs only, not IDs<br/>assigned courses + status"]
            S6["error_reports<br/>bug/wrong_finding/crash<br/>open/acknowledged/resolved"]
        end

        subgraph AIR["Airtable - Read-only reporting"]
            AT1["One-way sync from Supabase<br/>One row per finding<br/>QA team + IDs view only"]
        end
    end

    %% REVIEWER TIER MAPPING

    subgraph TIER["REVIEWER TIER: Standards Mapping"]
        direction LR

        T1["id_assistant - Col B<br/>107 deterministic checks:<br/>CLO/MLO presence, Syllabus fields,<br/>Nav menu, Template structure,<br/>Assessment settings, Links/videos,<br/>WCAG existence checks<br/>Visible to: IDAs + IDs<br/>Verdicted by: IDAs first, IDs override"]

        T2["id - Col C<br/>42 qualitative checks<br/>uses standards_enrichment.yaml:<br/>Blooms alignment, CLO quality,<br/>UDL principles, Assessment design,<br/>Material-objective alignment,<br/>Activity engagement quality<br/>Visible to: IDs only<br/>Verdicted by: QA team IDs"]
    end

    %% IMPLEMENTATION PHASES

    subgraph PHASES["IMPLEMENTATION PHASES"]
        direction TB

        P0["PHASE 0: Bug Fixes<br/>- audit_report.py URL fix<br/>- HTML/XLSX report data mapping<br/>- Staging workflow simplification"]

        P1["PHASE 1: Audit Skill Foundation<br/>- Map 25 standards to reviewer_tier<br/>- Update deterministic_checks.py<br/>- Capture evidence per finding<br/>- Add IDA Mode 5<br/>- Write new fields to Supabase"]

        P2["PHASE 2: Supabase Schema<br/>- New fields on existing tables<br/>- testers table<br/>- tester_course_assignments table<br/>- error_reports table<br/>- RLS policies"]

        P3["PHASE 3: Vercel App<br/>- Supabase Auth email + password<br/>- Role-based views: IDA/ID/QA/Admin<br/>- Finding card with inline evidence<br/>- Submit for QA Review workflow<br/>- Admin dashboard"]

        P4["PHASE 4: Airtable Integration<br/>- Supabase to Airtable batch sync<br/>- Nightly catch-up job<br/>- Read-only Airtable view"]

        P5["PHASE 5: RLHF and Admin Skills<br/>- assignments skill<br/>- assign skill<br/>- report-error skill<br/>- update-idw skill<br/>- RLHF pattern analysis"]

        P0 --> P1 --> P2 --> P3 --> P4 --> P5
    end

