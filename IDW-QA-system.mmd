%%{init: {'theme': 'dark', 'themeVariables': {'fontSize': '14px'}}}%%

%% IDW QA Full System Diagram
%% Last updated: 2026-03-31

flowchart TD

    %% PHASE 1: AUDIT

    subgraph AUDIT["PHASE 1: AUDIT (Claude Code — ID/IDA)"]
        direction TB

        A1(["ID opens Claude Code → /audit"]) --> A2
        A2{"Which course?<br/>Current / Pick / Batch"} --> A3
        A3{"Which mode?<br/>Quick / Deep / Guided"} --> A4
        A4["Claude fetches all course data<br/>pages, quizzes, assignments, discussions"] --> A5
        A5["Evaluates 173 criteria from standards.yaml<br/>B-XX.Y (readiness) + C-XX.Y (design)<br/>Per criterion: Met / Not Met / N/A"] --> A6
        A6["Results pushed to:<br/>• Supabase: ~174 finding rows<br/>• HTML report: local + Supabase storage<br/>• Session status: in_progress"]
    end

    %% PHASE 2: REVIEW

    subgraph REVIEW["PHASE 2: REVIEW (Vercel App — ID/IDA)"]
        direction TB

        B1["ID opens session in Vercel"] --> B2
        B2["Findings grouped by standard<br/>Each expandable: B-criteria + C-criteria<br/>Criterion question (italic) + Evidence (specific)"] --> B3
        B3["ID reviews each finding"] --> B4

        B4{"Verdict"}
        B4 -->|Correct + needs fix| B5["☑ Needs remediation<br/>Flagged for fix queue"]
        B4 -->|Correct, no fix needed| B6["Finding confirmed<br/>No action needed"]
        B4 -->|Incorrect| B7["AI was wrong<br/>ID provides correction"]
        B4 -->|N/A| B8["Doesn't apply<br/>to this course"]

        B5 --> B9
        B6 --> B9
        B7 --> B9
        B8 --> B9
        B9["ID marks session Complete"] --> B10
        B10["Col C findings → auto qa_approved<br/>Col B findings → pending_qa_review"]
    end

    AUDIT --> REVIEW

    %% PHASE 3: ID ASSISTANT VALIDATION

    subgraph VALIDATE["PHASE 3: VALIDATION (Vercel App — ID Assistant only)"]
        direction TB

        C1["ID Assistant opens session<br/>Sees Col B findings only"] --> C2
        C2["Reviews each B-criterion<br/>the ID already verdicted"] --> C3

        C3{"Round 1:<br/>Correct / Incorrect / N/A"}
        C3 -->|All agree| C4["All Col B: qa_approved<br/>Session complete"]
        C3 -->|Any disagree| C5["Provides reason<br/>Session: revisions_required<br/>remediation_requested = true"]
    end

    REVIEW --> VALIDATE

    %% PHASE 4: REMEDIATION

    subgraph REMEDIATE["PHASE 4: REMEDIATION (Claude Code — ID only)"]
        direction TB

        D1["ID opens Claude Code → /course-review"] --> D2
        D2["Fix queue loads from Supabase<br/>Shows findings where<br/>remediation_requested = true"] --> D3
        D3["ID picks an item:<br/>'Fix the alt text issues'"] --> D4
        D4["Claude does FOCUSED re-scan:<br/>Fetches pages, finds every instance<br/>Lists: 'Found 96 images across 68 pages'"] --> D5
        D5["Claude generates fixes<br/>Alt text via vision API<br/>Heading fixes, rubric generation"] --> D6
        D6["Stage → Screenshot → Preview"] --> D7

        D7{"ID approves?"}
        D7 -->|Yes| D8["Push to Canvas<br/>Record remediation_event<br/>Clear remediation_requested"]
        D7 -->|Change needed| D6
    end

    C5 --> REMEDIATE
    B5 --> REMEDIATE

    %% POST-REMEDIATION VALIDATION

    subgraph POSTVAL["PHASE 4b: POST-REMEDIATION VALIDATION (Vercel — ID Assistant)"]
        direction TB

        E1["ID Assistant sees remediated finding:<br/>ID Decision: Correct<br/>→ Remediated via /bulk-edit"] --> E2

        E2{"Agree / Disagree"}
        E2 -->|Agree| E3["Finding: qa_approved"]
        E2 -->|Disagree| E4["Reason: '5 images still missing'<br/>remediation_requested = true<br/>Back to fix queue"]
    end

    D8 --> POSTVAL
    E4 --> D2

    %% PHASE 5: AIRTABLE SYNC

    subgraph SYNC["PHASE 5: SYNC (Manual — Admin)"]
        direction TB

        F1["All findings qa_approved"] --> F2
        F2["Admin clicks Sync to Airtable<br/>on Vercel session page"] --> F3
        F3["airtable_sync.py runs<br/>• One row per course<br/>• 147 B/C columns: Yes/No/N/A<br/>• Standard ratings + Notes<br/>• High-level summary for faculty"]
    end

    E3 --> F1
    C4 --> F1

    %% AIRTABLE OUTPUT

    subgraph AIRTABLE["AIRTABLE (Read-only output)"]
        direction TB

        G1["QA team filters by school/program"] --> G2
        G2["Faculty outreach from Notes column"] --> G3
        G3["3x yearly presentations<br/>to academic units"]
    end

    F3 --> AIRTABLE

    %% RECURRING WORKFLOW

    subgraph RECURRING["RECURRING COURSE AUDIT"]
        direction TB

        H1(["Admin runs /audit"]) --> H2
        H2["ID Assistant reviews Col B only<br/>Correct / Incorrect / N/A"] --> H3
        H3["Admin spot-checks<br/>Sends faculty outreach"] --> H4
        H4["Sync to Airtable<br/>No remediation — findings only"]
    end

    %% SYSTEM COMPONENTS

    subgraph STACK["SYSTEM COMPONENTS"]
        direction TB

        subgraph CC["Claude Code"]
            CC1["/audit — 173 criteria evaluation<br/>Quick / Deep / Guided / Batch"]
            CC2["/course-review — fix queue + review<br/>Course list → pick → remediate"]
            CC3["/bulk-edit, /quiz, /rubric-creator<br/>Focused re-scan + fix + stage + push"]
            CC4["/admin — error queue, RLHF stats<br/>tester mgmt, Airtable sync"]
            CC5["/assignments — view assigned courses"]
        end

        subgraph VER["Vercel App"]
            V1["ID View: all findings (B+C)<br/>Grouped by standard, expandable<br/>Correct/Incorrect/N/A + needs remediation"]
            V2["ID Asst View: Col B only<br/>Round 1: Correct/Incorrect<br/>Round 2+: Agree/Disagree"]
            V3["Admin View: Sync button<br/>Report download, session mgmt"]
            V4["Category filter:<br/>Design / Readiness / A11y"]
        end

        subgraph SB["Supabase"]
            S1["audit_sessions — status, scores, round"]
            S2["audit_findings — per-criterion<br/>criterion_id (B-XX.Y / C-XX.Y)<br/>ai_reasoning + content_excerpt"]
            S3["finding_feedback — verdicts + history"]
            S4["remediation_events — what/when/how/who"]
            S5["testers + assignments + errors"]
        end

        subgraph AT["Airtable"]
            AT1["Course Audits table<br/>One row per course<br/>147 B/C columns + ratings + notes"]
            AT2["Views: ID/IDA | ID Assistant | Admin"]
        end
    end

    %% RLHF LOOP

    subgraph RLHF["RLHF FEEDBACK LOOP"]
        direction TB

        R1["Disagreements accumulate<br/>in finding_feedback"] --> R2
        R2["rlhf_analysis.py:<br/>Agreement rate by standard/reviewer"] --> R3
        R3["Admin diagnoses root cause:<br/>Prompt / Enrichment / Standard / Check"] --> R4
        R4["Fix pushed via /update-idw<br/>Next audit uses improved prompts"]
    end

